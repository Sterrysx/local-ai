def load_estimates():
    try:
        if os.path.exists(ESTIMATES_PATH):
            with open(ESTIMATES_PATH, "r") as f: return json.load(f)
    except: pass
    return {"code-qwen-80B": 25, "qwen-32B": 20, "llama-70B": 45, "default": 30}

def save_estimates(data):
    try:
        os.makedirs(os.path.dirname(ESTIMATES_PATH), exist_ok=True)
        with open(ESTIMATES_PATH, "w") as f: json.dump(data, f)
    except: pass

def load_config():
    with open(CONFIG_PATH, "r") as f: return json.load(f)

def get_status():
    try:
        cfg = load_config()
        url = f"http://{cfg['settings']['admin_host']}:{cfg['settings']['admin_port']}/internal/status"
        req = urllib.request.Request(url)
        req.add_header("Authorization", f"Bearer {API_KEY}")
        with urllib.request.urlopen(req, timeout=2) as r: return json.loads(r.read())
    except: return {}

class LocaiCompleter(Completer):
    def __init__(self):
        self.commands = ["/use", "/models", "/clear", "/compact", "/undo", "/retry", "/save", "/resume", "/status", "/vram", "/help", "/exit"]

    def get_completions(self, document, complete_event):
        text = document.text_before_cursor
        if text.startswith("/use "):
            sub = text[5:]
            for m in get_status().get("available_models", []):
                if m.startswith(sub): yield Completion(m, start_position=-len(sub))
        elif text.startswith("/resume "):
            sub = text[8:]
            if os.path.exists(HISTORY_DIR):
                for h in [f.replace(".json", "") for f in os.listdir(HISTORY_DIR) if f.endswith(".json")]:
                    if h.startswith(sub): yield Completion(h, start_position=-len(sub))
        elif text.startswith("/"):
            for cmd in self.commands:
                if cmd.startswith(text): yield Completion(cmd, start_position=-len(text))

